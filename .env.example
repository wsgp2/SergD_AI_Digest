# Telegram API credentials (get at https://my.telegram.org/apps)
API_ID=12345678
API_HASH=your_api_hash_here
PHONE=+70000000000

# Telethon session file name (without extension)
SESSION_NAME=session

# User ID to send digest to (your own Telegram user_id)
# Get yours by messaging @userinfobot
DIGEST_RECIPIENT_ID=123456789

# Claude model: "opus" or "sonnet" (uses claude CLI subscription)
DIGEST_MODEL=opus

# Telegram folder share link to auto-import on setup
# (get from Telegram: Settings → Folders → Share folder → copy link)
CHATLIST_INVITE=

# Local timezone for digest scheduling (IANA name)
# Examples: Asia/Makassar (Bali, UTC+8), Europe/Moscow (UTC+3)
TIMEZONE=Asia/Makassar

# Hour of day to send digest (local time, 24h format)
DIGEST_HOUR=8
